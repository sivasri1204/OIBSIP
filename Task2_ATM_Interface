import java.util.*;

class Account {
    String userId;
    String pin;
    double balance;
    ArrayList<String> history;

    Account(String userId, String pin, double balance) {
        this.userId = userId;
        this.pin = pin;
        this.balance = balance;
        history = new ArrayList<>();
    }
}

public class ATMInterface {

    static Scanner sc = new Scanner(System.in);
    static Map<String, Account> accounts = new HashMap<>();
    static Account currentUser;

    public static void main(String[] args) {

        // Creating sample accounts
        accounts.put("1001", new Account("1001", "1234", 5000));
        accounts.put("1002", new Account("1002", "4321", 8000));
        accounts.put("1003", new Account("1003", "5678", 10000));

        if (login()) {
            showMenu();
        } else {
            System.out.println("Too many failed attempts. Exiting system.");
        }
    }

    // LOGIN SYSTEM
    static boolean login() {

        int attempts = 0;

        while (attempts < 3) {

            System.out.print("Enter User ID: ");
            String id = sc.nextLine();

            System.out.print("Enter PIN: ");
            String pin = sc.nextLine();

            if (accounts.containsKey(id) && accounts.get(id).pin.equals(pin)) {
                currentUser = accounts.get(id);
                System.out.println("\nLogin Successful!");
                return true;
            } else {
                attempts++;
                System.out.println("Invalid credentials. Attempts left: " + (3 - attempts));
            }
        }

        return false;
    }

    // ATM MENU
    static void showMenu() {

        int choice;

        do {
            System.out.println("\n===== ATM MENU =====");
            System.out.println("1. Transaction History");
            System.out.println("2. Withdraw");
            System.out.println("3. Deposit");
            System.out.println("4. Transfer");
            System.out.println("5. Quit");

            System.out.print("Enter choice: ");
            choice = sc.nextInt();

            switch (choice) {

                case 1:
                    showHistory();
                    break;

                case 2:
                    withdraw();
                    break;

                case 3:
                    deposit();
                    break;

                case 4:
                    transfer();
                    break;

                case 5:
                    System.out.println("Thank you for using ATM!");
                    break;

                default:
                    System.out.println("Invalid option.");
            }

        } while (choice != 5);
    }

    // TRANSACTION HISTORY
    static void showHistory() {

        System.out.println("\n--- Transaction History ---");

        if (currentUser.history.isEmpty()) {
            System.out.println("No transactions yet.");
        } else {
            for (String h : currentUser.history) {
                System.out.println(h);
            }
        }
    }

    // DEPOSIT
    static void deposit() {

        System.out.print("Enter amount to deposit: ");
        double amount = sc.nextDouble();

        currentUser.balance += amount;
        currentUser.history.add("Deposited: ₹" + amount);

        System.out.println("Deposit successful.");
        System.out.println("Current Balance: ₹" + currentUser.balance);
    }

    // WITHDRAW
    static void withdraw() {

        System.out.print("Enter amount to withdraw: ");
        double amount = sc.nextDouble();

        if (amount > currentUser.balance) {
            System.out.println("Insufficient balance.");
        } else {
            currentUser.balance -= amount;
            currentUser.history.add("Withdrawn: ₹" + amount);

            System.out.println("Withdrawal successful.");
            System.out.println("Current Balance: ₹" + currentUser.balance);
        }
    }

    // TRANSFER
    static void transfer() {

        sc.nextLine(); // clear buffer

        System.out.print("Enter recipient User ID: ");
        String id = sc.nextLine();

        if (!accounts.containsKey(id)) {
            System.out.println("User not found.");
            return;
        }

        System.out.print("Enter amount to transfer: ");
        double amount = sc.nextDouble();

        if (amount > currentUser.balance) {
            System.out.println("Insufficient balance.");
            return;
        }

        Account receiver = accounts.get(id);

        currentUser.balance -= amount;
        receiver.balance += amount;

        currentUser.history.add("Transferred ₹" + amount + " to User " + id);

        System.out.println("Transfer successful.");
        System.out.println("Current Balance: ₹" + currentUser.balance);
    }
}
